; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="SignalBus"
run/main_scene="uid://dfyt7blif6gcv"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="uid://dwspf0y8fcyy7"

[autoload]

SignalBus="*res://addons/SignalBus/scripts/signal_bus.gd"

[debug]

gdscript/warnings/directory_rules={
"res://addons": 0,
"res://addons/gut": 0,
"res://addons/gut/not_a_real_file": 0
}

[dotnet]

project/assembly_name="signal_bus"

[editor_plugins]

disabled=PackedStringArray("res://addons/SignalBus/plugin.cfg")
enabled=PackedStringArray("res://addons/SignalBus/plugin.cfg", "res://addons/gut/plugin.cfg")

[signal_bus]

signals=Dictionary[String, Array]({
"test_signal": [{
"name": "param_a",
"type": 2
}]
})
